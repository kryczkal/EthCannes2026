{
  "name": "npmguard-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "demo:build": "node ./scripts/build-demo-manifest.js",
    "demo:upload": "node ./scripts/build-demo-manifest.js --upload",
