    "demo:publish": "node ./scripts/build-demo-manifest.js --upload && node ./scripts/publish-demo-to-ens.js",
    "sginstall": "node ./packages/sginstall/bin/sginstall.js"
  },
  "dependencies": {
    "@ensdomains/content-hash": "^3.0.0",
    "ipfs-only-hash": "^4.0.0",
    "multiformats": "^13.4.1",
    "pinata": "^2.5.5",
    "tar": "^7.5.13",
    "viem": "^2.47.6"
  }
}
