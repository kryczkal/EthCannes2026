# Temporal
NPMGUARD_TEMPORAL_HOST=localhost
NPMGUARD_TEMPORAL_PORT=7233
NPMGUARD_TASK_QUEUE=npmguard-task-queue

# API
NPMGUARD_API_HOST=0.0.0.0
NPMGUARD_API_PORT=8000

# LLM defaults
NPMGUARD_LLM_BACKEND=openai_compatible
NPMGUARD_LLM_MODEL=claude-sonnet-4-6
NPMGUARD_LLM_BASE_URL=
NPMGUARD_LLM_API_KEY=
NPMGUARD_LLM_TIMEOUT_SECONDS=60

# Example 0G setup:
# NPMGUARD_LLM_BACKEND=openai_compatible
# NPMGUARD_LLM_MODEL=qwen/qwen-2.5-7b-instruct
# NPMGUARD_LLM_API_KEY=app-sk-...
# NPMGUARD_LLM_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
