# API
NPMGUARD_API_HOST=0.0.0.0
NPMGUARD_API_PORT=8000

# LLM backend: "anthropic" or "openai_compatible"
NPMGUARD_LLM_BACKEND=anthropic

# Per-phase model overrides (defaults shown)
# NPMGUARD_TRIAGE_MODEL=claude-haiku-4-5-20251001
# NPMGUARD_INVESTIGATION_MODEL=claude-sonnet-4-6
# NPMGUARD_TEST_GEN_MODEL=claude-sonnet-4-6

# OpenAI-compatible / 0G settings (required when NPMGUARD_LLM_BACKEND=openai_compatible)
# NPMGUARD_LLM_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
# NPMGUARD_LLM_API_KEY=app-sk-...
NPMGUARD_LLM_TIMEOUT_SECONDS=60

# Investigation
# NPMGUARD_INVESTIGATION_ENABLED=true
# NPMGUARD_MAX_AGENT_TURNS=30

# Sandbox
# NPMGUARD_SANDBOX_IMAGE=node:22-slim
# NPMGUARD_SANDBOX_MEMORY_MB=512
# NPMGUARD_SANDBOX_CPUS=1
# NPMGUARD_SANDBOX_NETWORK=none
# NPMGUARD_MAX_DOCKER_EXEC_TIMEOUT_SEC=30
